{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CuraIQ",
  "version": "0.11.6",
  "identifier": "run.glick.curaiq",
  "build": {
    "frontendDist": "../.tauridist",
    "beforeBuildCommand": "node scripts/stage-frontend.mjs",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CuraIQ — Managed AI Host",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8787 ws://localhost:8787 https://raiseme.glick.run wss://raiseme.glick.run https://api.anthropic.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://raiseme.glick.run/api/update"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxOTlDMDczNDAwOTY4MjYKUldRbWFBbEFjOENaMGYyQVRqMmZwOHNGNUo5VHpoOWU5RWpyaENOODVYZEw3ZHNVcFE0S1ZNZFQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
