{
  "name": "raiseme",
  "version": "0.11.5",
  "type": "node",
  "entry": "server/server.js",
  "start": "node --no-warnings server/server.js",
  "port": 8787,
  "healthCheck": "/api/health",
  "env": {
    "PORT": "8787",
    "DB_PATH": "data/raiseme.db"
  },
  "cron": [
    {
      "name": "weekly-report",
      "schedule": "0 9 * * 1",
      "command": "node /app/server/jobs/weekly-report.mjs",
      "timeout_seconds": 300
    }
  ]
}
